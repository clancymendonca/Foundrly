# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-02
SANITY_WRITE_TOKEN=your_write_token
SANITY_API_TOKEN=your_api_token

# NextAuth (v5 accepts AUTH_SECRET or NEXTAUTH_SECRET)
AUTH_SECRET=your_auth_secret_minimum_32_characters
# Mobile app JWT (falls back to AUTH_SECRET if unset)
MOBILE_JWT_SECRET=your_mobile_jwt_secret_minimum_32_characters
NEXTAUTH_URL=http://localhost:3000

# Firebase Auth (server — service account from Firebase Console → Project Settings → Service accounts)
FIREBASE_PROJECT_ID=foundrly-8a047
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# File storage (production / Vercel Blob)
BLOB_READ_WRITE_TOKEN=your_blob_token

# Stream Chat
NEXT_PUBLIC_STREAM_API_KEY=your_stream_api_key
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# Web push (VAPID) — used by app/api/push-notifications/send (web-push library)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=noreply@foundrly.com

# Firebase (Stream Chat push via FCM)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Required for FCM getToken(): Web Push certificate from Firebase Console
# → Project Settings → Cloud Messaging → Web Push certificates (Generate key pair)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# AI providers
GEMINI_API_KEY=your_gemini_api_key
PINECONE_API_KEY=your_pinecone_api_key
GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional
ADMIN_SECRET=
QUIET_AI_LOGS=false
SUPPRESS_AI_ERRORS=false
