{
  "name": "foundrly-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @foundrly/web",
    "dev:mobile": "npm run start -w @foundrly/mobile",
    "build": "npm run build -w @foundrly/web",
    "start": "npm run start -w @foundrly/web",
    "lint": "npm run lint -w @foundrly/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test -w @foundrly/web",
    "test:run": "npm run test:run -w @foundrly/web",
    "verify:ci": "npm run verify:ci -w @foundrly/web"
  },
  "packageManager": "npm@10.5.2",
  "overrides": {
    "@foundrly/web": {
      "react": "^18.2.0",
      "react-dom": "^18.2.0",
      "next": "15.6.0-canary.61"
    },
    "@foundrly/mobile": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  },
  "devDependencies": {
    "expo": "~56.0.9",
    "expo-router": "~56.2.9",
    "typescript": "^5.7.3"
  }
}
