EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_STREAM_API_KEY=
EXPO_PUBLIC_SANITY_PROJECT_ID=
EXPO_PUBLIC_SANITY_DATASET=production
EXPO_PUBLIC_SANITY_API_VERSION=2025-01-02
EXPO_PUBLIC_SENTRY_DSN=

# Firebase Auth (same project as web; enable Google, Email, GitHub in Firebase Console)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Google Sign-In on native: OAuth 2.0 Web client ID from Firebase/Google Cloud
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# GitHub mobile OAuth (separate from Firebase Console GitHub provider on web)
EXPO_PUBLIC_GITHUB_CLIENT_ID=
