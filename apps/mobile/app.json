{
  "expo": {
    "name": "Foundrly",
    "slug": "foundrly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "foundrly",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foundrly.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4E71FF",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.foundrly.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#4E71FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "foundrly-mobile"
      }
    }
  }
}
